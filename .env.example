# Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000

# MongoDB Atlas Connection String
# Get yours at: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mediqueue?retryWrites=true&w=majority

# AI Provider: "gemini" or "openai"
AI_PROVIDER=gemini

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# SMS/OTP Provider (optional)
# Set SMS_PROVIDER=twilio to send real OTP SMS
SMS_PROVIDER=
SMS_DEFAULT_COUNTRY_CODE=+91
OTP_BRAND_NAME=MediQueue AI

# Twilio credentials (required when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
