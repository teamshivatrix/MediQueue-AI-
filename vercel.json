{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend-patient/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-admin/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/patient/css/(.*)",
      "dest": "/frontend-patient/css/$1"
    },
    {
      "src": "/patient/js/(.*)",
      "dest": "/frontend-patient/js/$1"
    },
    {
      "src": "/admin/css/(.*)",
      "dest": "/frontend-admin/css/$1"
    },
    {
      "src": "/admin/js/(.*)",
      "dest": "/frontend-admin/js/$1"
    },
    {
      "src": "/patient/(.+)",
      "dest": "/frontend-patient/$1"
    },
    {
      "src": "/admin/(.+)",
      "dest": "/frontend-admin/$1"
    },
    {
      "src": "/patient/?$",
      "dest": "/frontend-patient/index.html"
    },
    {
      "src": "/admin/?$",
      "dest": "/frontend-admin/admin-login.html"
    },
    {
      "src": "/$",
      "headers": { "Location": "/patient/index.html" },
      "status": 302
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "/api/index.js"
    }
  ]
}
