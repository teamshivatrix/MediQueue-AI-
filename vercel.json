{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend-patient/**",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-admin/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/frontend-patient/index.html"
    },
    {
      "src": "/patient/?",
      "dest": "/frontend-patient/index.html"
    },
    {
      "src": "/admin/?",
      "dest": "/frontend-admin/admin-login.html"
    },
    {
      "src": "/patient/(.*)",
      "dest": "/frontend-patient/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/frontend-admin/$1"
    },
    {
      "src": "/index.html",
      "dest": "/frontend-patient/index.html"
    },
    {
      "src": "/auth.html",
      "dest": "/frontend-patient/auth.html"
    },
    {
      "src": "/patient-home.html",
      "dest": "/frontend-patient/patient-home.html"
    },
    {
      "src": "/emergency-booking.html",
      "dest": "/frontend-patient/emergency-booking.html"
    },
    {
      "src": "/booking.html",
      "dest": "/frontend-patient/booking.html"
    },
    {
      "src": "/symptom-analyzer.html",
      "dest": "/frontend-patient/symptom-analyzer.html"
    },
    {
      "src": "/chatbot.html",
      "dest": "/frontend-patient/chatbot.html"
    },
    {
      "src": "/queue-display.html",
      "dest": "/frontend-patient/queue-display.html"
    },
    {
      "src": "/admin-login.html",
      "dest": "/frontend-admin/admin-login.html"
    },
    {
      "src": "/admin-dashboard.html",
      "dest": "/frontend-admin/admin-dashboard.html"
    },
    {
      "src": "/doctor-management.html",
      "dest": "/frontend-admin/doctor-management.html"
    }
  ]
}
